@model IEnumerable<MKSVY.Models.DistrictswiseSummary>
@{
    ViewBag.Title = "DashBoard Page";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title></title>
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/1.10.20/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/responsive/2.1.1/css/responsive.bootstrap.min.css" rel="stylesheet" />

    <style>
        table.table-fit {
            width: auto !important;
            table-layout: auto !important;
        }

            table.table-fit thead th,
            table.table-fit tbody td,
            table.table-fit tfoot th,
            table.table-fit tfoot td {
                width: auto !important;
            }

        .Sum_header {
            height: 1px;
            background-color: #5d9cd2;
            color: black;
            border: 1px !important;
            font-size: 14px;
            text-align: center;
            vertical-align: middle;
            font-weight: 100
        }

        #example2 {
            border: 1px solid;
            padding: 10px;
            box-shadow: 5px 10px #888888;
        }
    </style>

</head>

<body style="margin-left:0%;">
    <div class="row">
        <div class="col-sm-12">
            <h4 id="example2" style="font-weight:bold;width:100%;text-align: center;">
                District Wise Summary
            </h4>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-lg-12">
            <table id="tblSubstation" class="table table-striped table-bordered dt-responsive" style="width:100%;font-size:14px;color:black;text-align:center;font-weight:bold">
                <thead class="Sum_header">
                    <tr>
                        <th>
                            District
                        </th>
                        <th>
                            Total No. Of Sub station
                        </th>
                        <th>
                            Total Cluster Solar Capacity (In MW)
                        </th>
                        <th>
                            Total Land Required for Cluster (in acre)
                        </th>
                        <th>
                            Total Land Required for Cluster with 5 % tolerance (in acre)
                        </th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in (IEnumerable<MKSVY.Models.DistrictswiseSummary>)ViewData["DistrictWiseCount"])
                    {
                        <tr>
                            <td style="width:23%">
                                @Html.HiddenFor(modelItem => item.DIST_CODE)
                                @*@Html.DisplayFor(modelItem => item.DIST_NAME)*@
                                @Html.ActionLink(item.DIST_NAME, "DataPoint", "DashBoard", new { Dist_code = item.DIST_CODE, augmny = "N" }, new { })
                            </td>
                            <td style="width:auto" class="text-nowrap">

                                @Html.DisplayFor(modelItem => item.TotalSubStation)

                            </td>
                            <td style="table-layout: auto; width: auto;">

                                @Html.DisplayFor(modelItem => item.TotalSolarCapacity)

                            </td>
                            <td style="width:auto">

                                @Html.DisplayFor(modelItem => item.TotalLandRequired)

                            </td>
                            <td style="width:auto">

                                @Html.DisplayFor(modelItem => item.TotalLandRequiredwith_5_tolerance)

                            </td>


                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <br />
    @*<div class="row">
            <div class="col-lg-12" style="width:1519px">
                <div class="col-xs-3" style="text-align: center;">

                </div>
                <div class="col-xs-3" style="text-align: center;">

                </div>
                <div class="col-xs-3" style="text-align: center;">

                </div>
                <div class="col-xs-3" style="text-align: right;">
                    <button type="button" class="btn btn-primary" onclick='window.location = "@Url.Action("DataPoint", "DashBoard")";'>Back To Dashboard </button>
                </div>
            </div>
        </div>*@
    <script src="https://ajax.aspnetcdn.com/ajax/jQuery/jquery-3.2.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.20/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.20/js/dataTables.bootstrap.min.js"></script>
    <script>

        $('#tblSubstation').dataTable({
        });
    </script>
    @*<script>
            $(document).ready(function () {
                $("#tblSubstation").freezeHeader();
            })
        </script>*@
</body>
</html>