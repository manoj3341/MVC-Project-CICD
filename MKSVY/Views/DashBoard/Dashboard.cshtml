            border: 1px solid;
            padding: 10px;
            box-shadow: 5px 10px #888888;
        }

        .gd_header_Dash {
            height: 1px;
            background-color: #5d9cd2;
            color: black;
            border: 1px !important;
            font-size: 15px;
            text-align: center;
            vertical-align: middle;
        }

        .stat-cards-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .stat-cards-item {
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            -ms-flex-wrap: wrap;
            flex-wrap: wrap;
            padding: 24px 19px;
            background-color: #FFFFFF;
            -webkit-box-shadow: 0px 15px 50px rgba(160, 163, 189, 0.1);
            box-shadow: 0px 15px 50px rgba(160, 163, 189, 0.1);
            border-radius: 10px;
            height: 100%;
        }

        .chartHeader {
            font-size: 22px;
            text-align: center;
        }

        .stat-cards {
            margin-right: -10px;
            margin-left: -10px;
        }

        .row {
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -ms-flex-wrap: wrap;
            flex-wrap: wrap;
            margin-right: -15px;
            margin-left: -15px;
        }

        .mb-5 {
            margin-bottom: 3rem !important;
        }
    </style>
</head>
