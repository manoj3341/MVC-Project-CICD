@model IEnumerable<MKSVY.Models.LandClearance>
@{
    ViewBag.Title = "DashBoard Page";
    var SubstationName = ViewData["SubstationName"];
    var Substation_Number = ViewData["Substation_Number"];
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title></title>
    @*<link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet" />
        <link href="https://cdn.datatables.net/1.10.20/css/dataTables.bootstrap.min.css" rel="stylesheet" />
        <link href="https://cdn.datatables.net/responsive/2.1.1/css/responsive.bootstrap.min.css" rel="stylesheet" />*@
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <style>
        table.table-fit {
            width: auto !important;
            table-layout: auto !important;
        }

            table.table-fit thead th,
            table.table-fit tbody td,
            table.table-fit tfoot th,
            table.table-fit tfoot td {
                width: auto !important;
            }

        .tbl_header {
            height: 1px;
            background-color: #5d9cd2;
            color: black;
            border: 1px !important;
            font-size: 12px;
            text-align: center;
            vertical-align: middle;
        }

        #example2 {
            border: 1px solid;
            padding: 10px;
            box-shadow: 5px 10px #888888;
        }
    </style>

</head>

<body style="margin-left:-7%;">
    <div class="container" style="width:1506px;margin-left: -12%; overflow:auto">

        <div class="row">
            <div class="col-sm-12">
                <h4 id="example2" style="font-weight:bold">

                    Land Details for Substation : @ViewData["Substation_Number"] - @ViewData["SubstationName"]
                </h4>
            </div>
        </div>
        <hr />
        <div class="row">
            <div class="col-lg-12">
                <table id="tblSubstation" class="table table-striped table-bordered dt-responsive" style="width:100%;font-size:11px;color:black">
                    <thead class="tbl_header">

                        <tr>
                            <th>
                                Land Type
                            </th>
                            <th>
                                Land Owner
                            </th>
                            <th>
                                Water Source
                            </th>
                            <th>
                                Mobile No.
                            </th>
                            <th>
                                Taluka
                            </th>
                            <th>
                                Village
                            </th>
                            <th>
                                Gram Panchayat
                            </th>
                            <th>
                                Survey No
                            </th>
                            <th>
                                Latitude
                            </th>
                            <th>
                                Longitude
                            </th>
                            <th>
                                Area (Acres)
                            </th>
                            <th>
                                Aerial Dist.(KM)
                            </th>
                            <th>
                                PROPOSAL SEND TO COLLECTOR
                            </th>
                            <th>
                                JM LAND STATUS
                            </th>
                            @*<th>
                                POSSESSION DONE OR NOT
                            </th>*@
                            <th>
                                Land Lease
                            </th>
                            <th>
                                TILR NOC
                            </th>
                            <th>
                                ZP NOC
                            </th>
                            <th>
                                Rehibili NOC
                            </th>
                            <th>
                                Forest NOC
                            </th>
                            <th>
                                TP NOC
                            </th>
                            <th>
                                Irrigation NOC
                            </th>
                            <th>
                                Mining NOC
                            </th>
                            <th>
                                PWD NOC
                            </th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in (IEnumerable<MKSVY.Models.LandClearance>)ViewData["LandClearance"])
                        {
                        <tr>

                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Land_Type)

                            </td>
                            <td style="width:20%">

                                @Html.DisplayFor(modelItem => item.Land_Owner)

                            </td>
                            <td style="table-layout: auto; width: 100%;">

                                @Html.DisplayFor(modelItem => item.Water_Source)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Mobile_No)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Taluka)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Village)

                            </td>
                            <td style="width:20%">

                                @Html.DisplayFor(modelItem => item.Gram_Panchayat)

                            </td>
                            <td style="width:100%" class="text-nowrap">

                                @Html.DisplayFor(modelItem => item.Survey_No)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Latitude)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Longitude)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Area_Acres)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.Aerial_Dist_KM_)

                            </td>
                            @if (item.Proposal_To_Collector == "Y")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.Land_Lease)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.Proposal_To_Collector == "N")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.Land_Lease)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>
                                    @*<i class="fa-solid fa-xmark" style="color: #e83211;"></i>*@
                                </td>
                            }
                            @if (item.JM_Land_Status == "Y")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.Land_Lease)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.JM_Land_Status == "N")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.Land_Lease)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>
                                    @*<i class="fa-solid fa-xmark" style="color: #e83211;"></i>*@
                                </td>
                            }
                            @*@if (item.possession_done_not == "Y")
                            {
                                <td style="width:10%">

                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.possession_done_not == "N")
                            {
                                <td style="width:10%">

                                   
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>
                                 
                                </td>
                            }*@
                            @if (item.Land_Lease == "Y")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.Land_Lease)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.Land_Lease == "N")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.Land_Lease)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>
                                    @*<i class="fa-solid fa-xmark" style="color: #e83211;"></i>*@
                                </td>
                            }

                            @if (item.TILR_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.TILR_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.TILR_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.TILR_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>
                                    @*<i class="fa-solid fa-xmark" style="color: #e83211;"></i>*@
                                </td>
                            }
                            @if (item.ZP_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.ZP_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.ZP_NOC == "N")
                            {
                                <td style="width:10%">

                                    @* @Html.DisplayFor(modelItem => item.ZP_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>
                                    @*<i class="fa-solid fa-xmark" style="color: #e83211;"></i>*@
                                </td>
                            }

                            @*<td style="width:10%">

            @Html.DisplayFor(modelItem => item.Rehibili_NOC)

        </td>*@
                            @if (item.Rehibili_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.Rehibili_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>

                                </td>
                            }
                            @*<td style="width:10%">

            @Html.DisplayFor(modelItem => item.Forest_NOC)

        </td>*@
                            @if (item.Forest_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.Forest_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>

                                </td>
                            }
                            @*<td style="width:10%">

            @Html.DisplayFor(modelItem => item.TP_NOC)

        </td>*@
                            @if (item.TP_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.TP_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>

                                </td>
                            }
                            @*<td style="width:10%">

            @Html.DisplayFor(modelItem => item.Irrigation_NOC)

        </td>*@
                            @if (item.Irrigation_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.Irrigation_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>

                                </td>
                            }
                            @*<td style="width:10%">

            @Html.DisplayFor(modelItem => item.Mining_NOC)

        </td>*@
                            @if (item.Mining_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.Mining_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>

                                </td>
                            }
                            @*<td style="width:10%">

            @Html.DisplayFor(modelItem => item.PWD_NOC)

        </td>*@
                            @if (item.PWD_NOC == "Y")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-check" style="font-size:18px;color:green"></i>
                                </td>
                            }
                            else if (item.PWD_NOC == "N")
                            {
                                <td style="width:10%">

                                    @*@Html.DisplayFor(modelItem => item.Rehibili_NOC)*@
                                    <i class="fa fa-close" style="font-size:18px;color:red"></i>

                                </td>
                            }
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <br />
        <div class="row">
            <div class="col-lg-12">
                <div class="col-xs-3" style="text-align: center;">

                </div>
                <div class="col-xs-3" style="text-align: center;">

                </div>
                <div class="col-xs-3" style="text-align: center;">

                </div>
                <div class="col-xs-3" style="text-align: right;">
                    <button type="button" class="btn btn-primary" onclick='window.location = "@Url.Action("SubstaionList", "Substaion",  new { Dist_code = ViewData["Dist_code"], status1 = 0})";'>Back To SubStation List </button>
                </div>
            </div>
        </div>
    </div>

    @*<script src="https://ajax.aspnetcdn.com/ajax/jQuery/jquery-3.2.1.min.js"></script>
        <script src="https://cdn.datatables.net/1.10.20/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.10.20/js/dataTables.bootstrap.min.js"></script>
        <script>

            $('#tblSubstation').dataTable({
            });
