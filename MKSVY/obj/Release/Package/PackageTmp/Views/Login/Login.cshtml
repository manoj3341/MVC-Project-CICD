@model MKSVY.Models.Login
@{
    ViewBag.Title = "DashBoard Page";
}
@*@import url('https://fonts.googleapis.com/css?family=Numans');*@

<head id="Head1" style="height: 100%" runat="server">

    <title>MES</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css" integrity="sha384-MCw98/SFnGE8fJT3GXwEOngsV7Zt27NXFoaoApmYm81iuXoPkFOJwJ8ERdknLPMO" crossorigin="anonymous">

    <!--Fontawesome CDN-->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.3.1/css/all.css" integrity="sha384-mzrmE5qonljUremFsqc01SB46JvROS7bZs3IO2EmfFsd15uHvIt+Y8vEf7N7fWAU" crossorigin="anonymous">
    <!--Custom styles-->
    <link rel="stylesheet" type="text/css" href="styles.css">
    <link href="~/Content/loginpage.css" rel="stylesheet" />
    <style>
        html, body {
            background-image: url('../../Images/SolarPanels.jpg');           
            background-size: cover;
            background-repeat: no-repeat;
            height: 100%;
            font-family: 'Numans', sans-serif;
        }

        .container {
            height: 100%;
            align-content: center;
        }

        .card {
            height: 370px;
            margin-top: auto;
            margin-bottom: auto;
            width: 400px;
            background-color: rgba(0,0,0,0.2) !important;
            box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.5) !important;
            margin-left:60%
        }

        .social_icon span {
            font-size: 60px;
            margin-left: 10px;
            color: #FFC312;
        }

            .social_icon span:hover {
                color: white;
                cursor: pointer;
            }

        .card-header h3 {
            color: white;
        }

        .social_icon {
            position: absolute;
            right: 20px;
            top: -45px;
        }

        .input-group-prepend span {
            width: 50px;
            background-color: #FFC312;
            color: black;
            border: 0 !important;
        }

        input:focus {
            outline: 0 0 0 0 !important;
            box-shadow: 0 0 0 0 !important;
        }

        .remember {
            color: white;
            font-size:14px;
            
        }

            .remember input {
                width: 20px;
                height: 20px;
                margin-left: 15px;
                margin-right: 5px;
            }

        .login_btn {
            color: black;
            background-color: #FFC312;
            width: 100px;
            height:100%;
            font-size:12px;
            
        }

            .login_btn:hover {
                color: black;
                background-color: white;
            }

        .links {
            color: white;
        }

            .links a {
                margin-left: 4px;
            }
        .signlebel {
            text-align: center;
            color: orange;
            margin-bottom: 11%;
            font-size: 24px;
            font-weight: bold;
        }
    </style>
    <style>
        .loginLeft {
            position: fixed;
            left: 0;
            /*top: 0;*/
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
            background-color: white;
        }

        .loginRight {
            display: table;
            float: right;
            position: absolute;
            right: 0;
            height: 100%;
            width: 500px;
            /* z-index: 1; */
            overflow-x: hidden;
            overflow-y: auto;
            text-align: center;
            background-color: #fff;
            -webkit-transition: width 0.35s linear;
            -webkit-transition-delay: 0s;
            -moz-transition: width 0.35s linear 0s;
            -o-transition: width 0.35s linear 0s;
            transition: width 0.35s linear 0s;
        }

        .style_new {
            background-image: url(../assets/admin/layout2/img/srtp-login-img.jpg);
            background-repeat: no-repeat;
            background-position: center center;
            background-size: cover;
            height: 356px;
            width: 1524px;
        }

        .container_new {
            height: 100vh;
            width: 100vw;
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: center;
        }

        .card-21 {
            height: 200px;
            width: 200px;
            border-radius: 5px;
            border: 1px solid #ccc;
            box-shadow: rgba(0, 0, 0, 0.4) -5px 5px, rgba(0, 0, 0, 0.3) -10px 10px, rgba(0, 46, 170, 0.2) -15px 15px, rgba(0, 0, 0, 0.1) -10px 10px, rgba(0, 0, 0, 0.05) -0 0;
        }

        .Boxdiv {
            width: 100%;
            height: 100%;
            line-height: 70px;
            text-align: center;
            color: white;
            background-color: transparent;
            margin: 10px;
        }

        .Boxdivb {
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body style="margin-top: -3%">
    @using (Html.BeginForm("Login", "Login", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="container">
            <div class="d-flex justify-content-center h-100">
                <div class="card">
                    <div class="card-header">
                        <h4 style="font-size: 22px;line-height: 30px;text-align: center;color: white;">
                        <strong>MSKVY 2.0 | Mukhyamantri Saur Krushi Vahini Yojana - 2.0</strong>
                        </h4>
                                                
                    </div>
                    <div class="card-body" style="margin-left:5%">
                        <h3 class="signlebel">Sign In</h3>
                        <form>
                            <div class="input-group form-group">
                                <div class="input-group-prepend" style="height:40px">
                                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                                </div>
                                @*<input type="text" class="form-control" placeholder="username">*@
                                @Html.EditorFor(model => model.LOGIN_ID, new { htmlAttributes = new { @class = "form-control", placeholder = "User Name", style = "height: 40px" } })
                            </div>
                            <div class="input-group form-group">
                                <div class="input-group-prepend" style="height:40px">
                                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                                </div>
                                @*<input type="password" class="form-control" placeholder="password">*@
                                @Html.EditorFor(model => model.PASSWORD, new { htmlAttributes = new { @class = "form-control", placeholder = "Password", style = "height: 40px" } })
                            </div>
                            <div class="row align-items-center remember">
                                <input type="checkbox">Remember Me
                            </div>
                            <div class="form-group">
                                <input type="submit" value="Login" class="btn float-right login_btn" style="font-size:12px;font-weight:bold;margin-right:12%">
                            </div>
                        </form>
                    </div>
                    @*<div class="card-footer">
                        <div class="d-flex justify-content-center links">
                            Don't have an account?<a href="#">Sign Up</a>
                        </div>
                        <div class="d-flex justify-content-center">
                            <a href="#">Forgot your password?</a>
                        </div>
                    </div>*@
                </div>
            </div>
        </div>
    }
</body>