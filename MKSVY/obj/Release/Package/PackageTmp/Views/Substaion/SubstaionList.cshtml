@model IEnumerable<MKSVY.Models.SubstaionList>
@{
    ViewBag.Title = "DashBoard Page";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title></title>
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/1.10.20/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/responsive/2.1.1/css/responsive.bootstrap.min.css" rel="stylesheet" />

    <style>
        table.table-fit {
            width: auto !important;
            table-layout: auto !important;
        }

            table.table-fit thead th,
            table.table-fit tbody td,
            table.table-fit tfoot th,
            table.table-fit tfoot td {
                width: auto !important;
            }

        .tbl_header {
            height: 1px;
            background-color: #5d9cd2;
            color: black;
            border: 1px !important;
            font-size: 12px;
            text-align: center;
            vertical-align: middle;
            font-weight: 100
        }

        #example2 {
            border: 1px solid;
            padding: 10px;
            box-shadow: 5px 10px #888888;
        }
    </style>

</head>

<body style="margin-left:-23%;">
    <div class="row">
        <div class="col-sm-12">
            <h4 id="example2" style="font-weight:bold;width:130%;text-align: center;">
                Sub Station List Within  @ViewData["Dist_Name"]
            </h4>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-lg-12">
            <table id="tblSubstation" class="table table-striped table-bordered dt-responsive" style="width:100%;font-size:13px;color:black;text-align:center;">
                <thead class="tbl_header">
                    <tr>
                        <th rowspan="2">
                            TALUKA
                        </th>
                        <th rowspan="2">
                            S/DN
                        </th>
                        <th rowspan="2">
                            S/S Name
                        </th>
                        <th rowspan="2">
                            S/S Number
                        </th>
                        <th rowspan="2">
                            Solar Capacity (MW)
                        </th>
                        <th rowspan="2">
                            Land Required (Acre)
                        </th>
                        <th colspan="2">Govt Feasible Lands</th>
                        <th colspan="2">Pvt Feasible Lands</th>
                        <th colspan="2">Proposal Submited Lands</th>
                        <th colspan="2">Possession RCVD Lands</th>
                        <th rowspan="2">
                            Useful Lands in Possession (Acre)
                        </th>
                        <th rowspan="2">
                            Status
                        </th>
                        <th rowspan="2">
                            View
                        </th>
                    </tr>
                    <tr>
                        @*<th>

                            </th>
                            <th>

                            </th>
                            <th>

                            </th>
                            <th>

                            </th>
                            <th>

                            </th>
                            <th>

                            </th>*@
                        <th>
                            Nos
                        </th>
                        <th>
                            Acres
                        </th>
                        <th>
                            Nos
                        </th>
                        <th>
                            Acres
                        </th>
                        <th>
                            Nos
                        </th>
                        <th>
                            Acres
                        </th>
                        <th>
                            Nos
                        </th>
                        <th>
                            Acres
                        </th>
                        @*<th>
                            </th>
                            <th>
                            </th>
                            <th>
                            </th>*@

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in (IEnumerable<MKSVY.Models.SubstaionList>)ViewData["substaionLists"])
                    {
                        <tr>
                            <td style="width:10%">
                                @Html.HiddenFor(modelItem => item.DIST_CODE)
                                @Html.DisplayFor(modelItem => item.TALUKA_NAME)

                            </td>
                            <td style="width:100%" class="text-nowrap">

                                @Html.DisplayFor(modelItem => item.SUBDIVISION)

                            </td>
                            <td style="table-layout: auto; width: 50%;" class="text-nowrap">

                                @Html.DisplayFor(modelItem => item.SUBSTATION_NAME)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.SUBSTATION_NO)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.SOLAR_CAPACITY_MW)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.LAND_REQUIRED_IN_ACRE)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.GOVT_FEASIBLE_LANDS)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.GOVT_FEASIBLE_LANDS_ACRE)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.PVT_FEASIBLE_LANDS)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.PVT_FEASIBLE_LANDS_ACRE)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.PROPOSAL_SUBMITED_LANDS)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.PROPOSAL_SUBMITED_ARCE)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.POSSION_RCVD_LAND)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.POSSION_RCVD_AREA)

                            </td>
                            <td style="width:10%">

                                @Html.DisplayFor(modelItem => item.USEFUL_LAND)

                            </td>

                            @if (Convert.ToDouble(item.LAND_REQUIRED_IN_ACRE) == Convert.ToDouble(item.USEFUL_LAND))
                            {
                                <td style="width: 100%; background-color: green; color:white;font-weight: bold;" class="text-nowrap">
                                    Completed
                                </td>
                            }
                            else if (Convert.ToDouble(item.LAND_REQUIRED_IN_ACRE) > Convert.ToDouble(item.USEFUL_LAND) && (Convert.ToDouble(item.PROPOSAL_SUBMITED_LANDS) != 0))
                            {
                                <td style="width: 100%; background-color: orange; color:white; font-weight: bold;" class="text-nowrap">
                                    In Progress
                                </td>
                            }
                            else if (item.PROPOSAL_SUBMITED_LANDS == 0)
                            {
                                <td style="width: 100%; background-color: red; color:white; font-weight: bold;" class="text-nowrap">
                                    Yet To Start
                                </td>
                            }
                            else
                            {
                                <td style="width: 100%; background-color: yellow; color:white; font-weight: bold;" class="text-nowrap">
                                    Miss Match
                                </td>
                            }
                            <td style="width:auto">
                                @Html.ActionLink("View", "LandClearance", "Land", new { Dist_code = item.DIST_CODE, substation_No = item.SUBSTATION_NO }, new { })

                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-lg-12" style="width:1519px">
            <div class="col-xs-3" style="text-align: center;">

            </div>
            <div class="col-xs-3" style="text-align: center;">

            </div>
            <div class="col-xs-3" style="text-align: center;">

            </div>
            <div class="col-xs-3" style="text-align: right;">
                <button type="button" class="btn btn-primary" onclick='window.location = "@Url.Action("DataPoint", "DashBoard", new { dist_code = @ViewData["Dist_code"] })";'>Back To Dashboard </button>
            </div>
        </div>
    </div>
    <script src="https://ajax.aspnetcdn.com/ajax/jQuery/jquery-3.2.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.20/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.20/js/dataTables.bootstrap.min.js"></script>
    <script>

        $('#tblSubstation').dataTable({
        });
    </script>
    @*<script>
            $(document).ready(function () {
                $("#tblSubstation").freezeHeader();
            })
        </script>*@
</body>
</html>